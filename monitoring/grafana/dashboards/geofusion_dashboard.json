{
  "id": null,
  "uid": "geofusion-main",
  "title": "GeoFusion AI Platform",
  "tags": ["geofusion", "satellite", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total API Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(geofusion_requests_total)",
          "legendFormat": "Total Requests"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "rate(geofusion_requests_total[1m])",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Retrieval Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(geofusion_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95 Latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "Embedding Requests by Sensor",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum by (sensor) (geofusion_embed_total)",
          "legendFormat": "{{sensor}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "FAISS Search Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(geofusion_search_latency_seconds_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Errors (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(geofusion_requests_total{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status}} errors"
        }
      ]
    }
  ]
}
