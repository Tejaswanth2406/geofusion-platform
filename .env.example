# ─── Service URLs (used by api-gateway) ──────────────────────────────────────
EMBEDDING_SERVICE_URL=http://localhost:8001
RETRIEVAL_SERVICE_URL=http://localhost:8002
EVAL_SERVICE_URL=http://localhost:8005

# ─── Model Config ─────────────────────────────────────────────────────────────
MODEL_TYPE=vit
EMBEDDING_DIM=512
CHECKPOINT_PATH=ai-models/checkpoints/best_model.pt

# ─── Vector Database ──────────────────────────────────────────────────────────
FAISS_INDEX_PATH=vector-database/faiss.index
METADATA_DB_PATH=vector-database/metadata.json

# ─── Storage (MinIO / S3) ─────────────────────────────────────────────────────
MINIO_ROOT_USER=geofusion
MINIO_ROOT_PASSWORD=geofusion123
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=satellite-data

# ─── Experiment Tracking ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
